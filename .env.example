# =============================================================================
# AGIR-UNB — variáveis de ambiente
# =============================================================================
# Copie para `.env` na raiz do repositório:
#   cp .env.example .env
#
# O `docker-compose.yml` carrega `.env` nos serviços (cli, dashboard, dani-worker).
# Para desenvolvimento local com `python -m ...`, o `python-dotenv` também lê `.env`
# quando o código instancia o serviço AWS (ex.: S3Service).
# =============================================================================

# -----------------------------------------------------------------------------
# Caminhos (Docker)
# -----------------------------------------------------------------------------
# Dentro dos containers o código usa `/app/data`, mapeado para `./data` no host.
DATA_DIR=/app/data

# Arquivo de palavras-chave do DANI (opcional).
# O serviço `dani-worker` no docker-compose define um valor padrão explícito.
# KEYWORDS_FILE=/app/data/dani/palavras_chaves.txt

# -----------------------------------------------------------------------------
# AWS (obrigatório para S3: upload LARA-I, download DANI, config órgãos no S3)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Opcional: região do bucket (boto3 também lê AWS_DEFAULT_REGION do ambiente).
# AWS_DEFAULT_REGION=us-east-1

# Nota: o nome do bucket está fixo no código (`agir-bucket`) para prefixos como
# `dani-docs/` e `lara-config/`. Ajustar o código se usar outro bucket.

# -----------------------------------------------------------------------------
# DANI (opcionais)
# -----------------------------------------------------------------------------
DANI_BATCH_SIZE=15
DANI_MAX_WORKERS=2

# Subpasta de PDFs em `data/dani/docs/input/` a processar: cig | pg | compliance
# DANI_INPUT_SUBDIR=cig

# -----------------------------------------------------------------------------
# AGIR-RAG Lite / Gemini (opcionais)
# -----------------------------------------------------------------------------
# Quando GEMINI_API_KEY estiver configurada, o dashboard usa Gemini como modo
# padrao para respostas do RAG. Sem a chave, o RAG segue funcionando em modo
# extrativo, apenas com evidencias recuperadas.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Opcional: endpoint para resposta via Ollama local/remoto.
# OLLAMA_BASE_URL=http://localhost:11434

# -----------------------------------------------------------------------------
# LARA-I (opcional)
# -----------------------------------------------------------------------------
# Tipos a coletar, separados por vírgula, se não usar `--tipos` na linha de comando:
# LARA_TIPOS_COLETA=cig,pg

# Quantos órgãos processar em paralelo (cada um com contexto Playwright próprio). Padrão no código: 4.
# LARA_CONCORRENCIA_ORGAOS=4

# -----------------------------------------------------------------------------
# Streamlit / logs (referência; o dashboard costuma receber flags no comando Docker)
# -----------------------------------------------------------------------------
# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_ADDRESS=0.0.0.0
# LOG_LEVEL=INFO
